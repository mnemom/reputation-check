{
  "name": "@mnemom/reputation-check",
  "version": "0.5.0",
  "private": true,
  "description": "GitHub Action to check Mnemom Trust Score",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "node --test __tests__/*.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check ."
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0"
  }
}
